# ============================================================
# MẪU biến môi trường — copy sang .env.local rồi điền giá trị thật
# File này AN TOÀN để commit (không chứa secret).
# ============================================================

# --- Supabase (frontend đọc bằng anon/publishable key) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-or-publishable-key>

# --- Supabase (server ghi bằng service_role key — giữ tuyệt mật) ---
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- Supabase Postgres (connection string; ký tự đặc biệt trong mật khẩu phải URL-encode) ---
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# --- DeepSeek (AI chấm điểm + tóm tắt tiếng Việt; OpenAI-compatible) ---
DEEPSEEK_API_KEY=<deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
